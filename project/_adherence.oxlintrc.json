{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/game/**",
              "ui_kits/grid-stella/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cinzel|Shippori Mincho|Zen Kaku Gothic New|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Cinzel, Shippori Mincho, Zen Kaku Gothic New, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|shape|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, shape, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|neutral|weapon|buff|defense|solid)$/]",
        "message": "<Badge> tone must be one of 'gold' | 'neutral' | 'weapon' | 'buff' | 'defense' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|square)$/]",
        "message": "<Badge> shape must be one of 'pill' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|iconLeft|iconRight|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, iconLeft, iconRight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ItemCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|nameJa|nameEn|type|width|height|attack|cooldown|effect|cost|selected|affordable|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<ItemCard> doesn't accept that prop. Declared props: icon, nameJa, nameEn, type, width, height, attack, cooldown, effect, cost, selected, affordable, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ItemCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:weapon|buff|defense)$/]",
        "message": "<ItemCard> type must be one of 'weapon' | 'buff' | 'defense'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|corners|scanlines|glow|as|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: children, corners, scanlines, glow, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|max|kind|showShield|shield|style|key|ref|className|style|children)$/]",
        "message": "<StatBar> doesn't accept that prop. Declared props: label, value, max, kind, showShield, shield, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBar'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:hp|enemy|shield)$/]",
        "message": "<StatBar> kind must be one of 'hp' | 'enemy' | 'shield'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
